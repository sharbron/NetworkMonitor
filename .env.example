# ── Grafana ──────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_secure_password
GF_SERVER_ROOT_URL=http://localhost:3000

# ── Ports ────────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
BLACKBOX_PORT=9115
NODE_EXPORTER_PORT=9100

# ── Prometheus Retention ─────────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=5GB

# ── Alertmanager - Slack (optional) ──────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE_ME
SLACK_CHANNEL=#network-alerts

# ── Alertmanager - Email (optional) ──────────────────────────────────────────
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_FROM=alerts@example.com
SMTP_AUTH_USERNAME=alerts@example.com
SMTP_AUTH_PASSWORD=your_app_password
ALERT_EMAIL_TO=you@example.com
